{
  "name": "sample_historical_data_quality_monitoring",
  "git_source": {
    "git_url": "https://github.com/fzha113/agent-data-profiling.git",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "tasks": [
    {
      "task_key": "sample_data_quality_monitoring",
      "spark_python_task": {
        "python_file": "jobs/run_sample_quality_monitoring.py",
        "source": "GIT"
      },
      "job_cluster_key": "small_job_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "small_job_cluster",
      "new_cluster": {
        "spark_version": "16.4.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 1,
        "data_security_mode": "SINGLE_USER"
      }
    }
  ],
  "queue": {
    "enabled": true
  },
  "max_concurrent_runs": 1
}
