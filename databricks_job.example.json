{
  "name": "kag_historical_data_quality_monitoring",
  "git_source": {
    "git_url": "https://github.com/FanZhang0/agent-data-profiling.git",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "tasks": [
    {
      "task_key": "create_kag_history_tables",
      "spark_python_task": {
        "python_file": "jobs/create_kag_history_tables.py",
        "source": "GIT"
      },
      "job_cluster_key": "small_job_cluster"
    },
    {
      "task_key": "data_outliers_check",
      "depends_on": [
        {
          "task_key": "create_kag_history_tables"
        }
      ],
      "spark_python_task": {
        "python_file": "jobs/run_outlier_check.py",
        "source": "GIT"
      },
      "job_cluster_key": "small_job_cluster"
    },
    {
      "task_key": "data_stuck_check",
      "depends_on": [
        {
          "task_key": "create_kag_history_tables"
        }
      ],
      "spark_python_task": {
        "python_file": "jobs/run_stuck_value_check.py",
        "source": "GIT"
      },
      "job_cluster_key": "small_job_cluster"
    },
    {
      "task_key": "incident_merging",
      "depends_on": [
        {
          "task_key": "data_outliers_check"
        },
        {
          "task_key": "data_stuck_check"
        }
      ],
      "run_if": "ALL_DONE",
      "spark_python_task": {
        "python_file": "jobs/merge_incidents.py",
        "source": "GIT"
      },
      "job_cluster_key": "small_job_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "small_job_cluster",
      "new_cluster": {
        "spark_version": "16.4.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 1,
        "data_security_mode": "SINGLE_USER"
      }
    }
  ],
  "queue": {
    "enabled": true
  },
  "max_concurrent_runs": 1
}
